{
  "name": "brain-spawn",
  "displayName": "Brain Spawn",
  "description": "Define and launch groups of pre-configured terminals with a single command",
  "version": "0.10.0",
  "publisher": "CodeontheRocks",
  "repository": {
    "type": "git",
    "url": "https://github.com/jtmuller5/brain-spawn"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "media/icons/brain-spawn.png",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "brainSpawn.launch",
        "title": "Brain Spawn: Launch"
      },
      {
        "command": "brainSpawn.newTerminal",
        "title": "Brain Spawn: New Terminal"
      },
      {
        "command": "brainSpawn.newPlanTerminal",
        "title": "Brain Spawn: New Plan Terminal"
      },
      {
        "command": "brainSpawn.newWorktreeTerminal",
        "title": "Brain Spawn: New Worktree Terminal"
      },
      {
        "command": "brainSpawn.openDashboard",
        "title": "Brain Spawn: Dashboard"
      },
      {
        "command": "brainSpawn.closeUntracked",
        "title": "Brain Spawn: Close Untracked Terminals"
      }
    ],
    "keybindings": [
      {
        "command": "brainSpawn.launch",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t"
      }
    ],
    "configuration": {
      "title": "Brain Spawn",
      "properties": {
        "brainSpawn.command": {
          "type": "string",
          "default": "claude",
          "description": "Command to run in each spawned terminal"
        },
        "brainSpawn.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start terminal cleanup, hook server, and Claude monitoring when VS Code starts. When disabled, the extension stays dormant until you run a Brain Spawn command."
        },
        "brainSpawn.openDashboardOnStart": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open the dashboard when VS Code starts"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/codicons": "^0.0.44",
    "esbuild": "^0.24.0",
    "typescript": "^5.3.0"
  }
}
