{
  "name": "brain-spawn",
  "displayName": "Brain Spawn",
  "description": "Define and launch groups of pre-configured terminals with a single command",
  "version": "0.13.0",
  "publisher": "CodeontheRocks",
  "repository": {
    "type": "git",
    "url": "https://github.com/jtmuller5/brain-spawn"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "media/icons/brain-spawn.png",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "brainSpawn",
          "title": "Brain Spawn",
          "icon": "media/icons/brain-spawn.svg"
        }
      ]
    },
    "views": {
      "brainSpawn": [
        {
          "id": "brainSpawnTerminals",
          "name": "Terminals"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "brainSpawn.openDashboard",
          "when": "view == brainSpawnTerminals",
          "group": "navigation"
        },
        {
          "command": "brainSpawn.launch",
          "when": "view == brainSpawnTerminals",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "brainSpawn.sidebar.showTerminal",
          "when": "view == brainSpawnTerminals && viewItem == terminal",
          "group": "inline"
        }
      ]
    },
    "commands": [
      {
        "command": "brainSpawn.launch",
        "title": "Brain Spawn: Launch",
        "icon": "$(add)"
      },
      {
        "command": "brainSpawn.newTerminal",
        "title": "Brain Spawn: New Terminal"
      },
      {
        "command": "brainSpawn.newPlanTerminal",
        "title": "Brain Spawn: New Plan Terminal"
      },
      {
        "command": "brainSpawn.newWorktreeTerminal",
        "title": "Brain Spawn: New Worktree Terminal"
      },
      {
        "command": "brainSpawn.openDashboard",
        "title": "Brain Spawn: Dashboard",
        "icon": "$(layout)"
      },
      {
        "command": "brainSpawn.closeUntracked",
        "title": "Brain Spawn: Close Untracked Terminals"
      },
      {
        "command": "brainSpawn.reinstallHooks",
        "title": "Brain Spawn: Reinstall Claude Hooks"
      },
      {
        "command": "brainSpawn.sidebar.focusTerminal",
        "title": "Focus Terminal"
      },
      {
        "command": "brainSpawn.sidebar.showTerminal",
        "title": "Show Terminal",
        "icon": "$(terminal)"
      }
    ],
    "keybindings": [
      {
        "command": "brainSpawn.launch",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t"
      }
    ],
    "configuration": {
      "title": "Brain Spawn",
      "properties": {
        "brainSpawn.command": {
          "type": "string",
          "default": "claude",
          "description": "Default command to run in each spawned terminal (deprecated — use brainSpawn.commands instead)"
        },
        "brainSpawn.commands": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Display name for the command (e.g. \"Claude\", \"Pi\")"
              },
              "command": {
                "type": "string",
                "description": "Command to run in the terminal (e.g. \"claude\", \"pi\")"
              }
            },
            "required": [
              "name",
              "command"
            ]
          },
          "default": [],
          "description": "List of commands available for spawning terminals. The first entry is used as the default. If empty, falls back to brainSpawn.command."
        },
        "brainSpawn.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start terminal cleanup, hook server, and Claude monitoring when VS Code starts. When disabled, the extension stays dormant until you run a Brain Spawn command."
        },
        "brainSpawn.openDashboardOnStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open the dashboard when VS Code starts"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/codicons": "^0.0.44",
    "esbuild": "^0.24.0",
    "typescript": "^5.3.0"
  }
}
